# Backend Environment Variables

# Server Port
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ofds?retryWrites=true&w=majority&authSource=admin

# JWT Secret (use a strong, random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Node Environment
NODE_ENV=development

# CORS Configuration (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.netlify.app
